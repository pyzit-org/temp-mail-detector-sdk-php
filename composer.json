{
    "name": "pyzit/tempmail",
    "version": "0.1.1",
    "description": "Official PHP SDK for the Pyzit disposable email detector API",
    "type": "library",
    "license": "MIT",
    "keywords": ["email", "disposable", "tempmail", "validation", "pyzit"],
    "homepage": "https://temp-mail-detector.pyzit.com",
    "authors": [
        {
            "name": "Pyzit",
            "email": "hi@pyzit.com"
        }
    ],
    "require": {
        "php": "^8.1",
        "ext-curl": "*",
        "ext-json": "*"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.5 || ^11.0",
        "php-mock/php-mock-phpunit": "^2.9"
    },
    "autoload": {
        "psr-4": {
            "Pyzit\\TempMail\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Pyzit\\TempMail\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "phpunit --testdox",
        "test:coverage": "phpunit --coverage-text"
    },
    "config": {
        "sort-packages": true
    },
    "minimum-stability": "stable"
}